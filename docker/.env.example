# docker compose --env-file .env
#
# Laravel DB/app: api/src/.env only

# Khớp api.stack trong docker/routes.json → container <prefix>-api-nginx
API_STACK_PREFIX=base

# Khớp BASE_SHARED_NETWORK_NAME trong docker/.env (gateway stack)
BASE_SHARED_NETWORK_NAME=base_shared_net

HOST_UID=1000
HOST_GID=1000
