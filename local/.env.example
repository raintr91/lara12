# Tuỳ chọn: docker compose --env-file .env … (chỉ khi override port/network)
#
# Cấu hình DB: chỉ trong api/src/.env (Laravel), khớp MySQL ở docker/.env.

# Prefix stack (chữ thường, số, gạch ngang): tên Compose project = api-<prefix>, container = <prefix>-api-php / <prefix>-api-nginx
API_STACK_PREFIX=base

BASE_SHARED_NETWORK_NAME=base_shared_net

# Cổng HTTP publish ra host — khớp API port (sau dấu phẩy đầu: …:PORT, … trong docker/routes.txt)
API_NGINX_HTTP_PORT=18080
