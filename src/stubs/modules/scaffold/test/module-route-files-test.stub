<?php

namespace $MODULE_NAMESPACE$\$STUDLY_NAME$\Tests\Feature;

use Tests\TestCase;

class ModuleRouteFilesTest extends TestCase
{
    public function test_module_route_files_exist(): void
    {
        $this->assertFileExists(module_path('$STUDLY_NAME$', 'Routes/api.php'));

        $authPath = module_path('$STUDLY_NAME$', 'Routes/auth.php');
        if (is_file($authPath)) {
            $this->assertFileExists($authPath);
        }
    }
}
