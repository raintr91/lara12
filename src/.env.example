APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.mairy.com
CHAIN_PORTAL_URL=https://chain.mairy.com

# Optional: GitHub token for composer install during Docker image build.
COMPOSER_GITHUB_TOKEN=

# When true, /api/chain/survey-analytics/* returns canned data (no DB / third-party).
SURVEY_ANALYTICS_MOCK=false

# When true, store APIs that depend on OTA / Toreta / tracker / surveys / delivery logs return canned payloads.
STORE_THIRD_PARTY_MOCK=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_local
DB_USERNAME=root
DB_PASSWORD=123456

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Origins được phép (CORS). Cách nhau dấu phẩy — full URL hoặc chỉ hostname (tự thêm https://).
# Ví dụ: portal-base.local.com,https://admin.example.com:8443
CORS_ALLOWED_ORIGINS=https://portal-base.local.com,https://portal-project1.local.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sqs

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.mairy.com
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_EHLO_DOMAIN=api.mairy.com
MAIL_FROM_ADDRESS="no-reply@api.mairy.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=smart-media
AWS_ENDPOINT=http://localstack.mairy.com
AWS_URL=http://localstack.mairy.com/smart-media
AWS_USE_PATH_STYLE_ENDPOINT=true

SQS_PREFIX=http://localstack.mairy.com/000000000000
SQS_QUEUE=queue_default.fifo

LOG_SLACK_WEBHOOK_URL=http://mock.mairy.com/slack/webhook
SLACK_HOOK=http://mock.mairy.com/slack/webhook
URL_API_AOSSMS=http://mock.mairy.com/send-sms
URL_API_AOSSMS_INTERNATIONAL=http://mock.mairy.com/send-sms
URL_API_AOSSMS_GET_STATUS=http://mock.mairy.com/sms/status
URL_API_AOSSMS_INTERNATIONAL_GET_STATUS=http://mock.mairy.com/sms/status

VITE_APP_NAME="${APP_NAME}"

# Model contract test behavior: false = soft pass on optional contracts, true = fail strict
MODEL_CONTRACT_STRICT=false
